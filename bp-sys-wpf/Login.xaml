<Window x:Class="bp_sys_wpf.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:bp_sys_wpf"
        mc:Ignorable="d"
        Title="Login" Height="244" Width="353" ResizeMode="CanMinimize" WindowStartupLocation="CenterScreen">
    <Grid>
        <Label Content="欢迎使用第五人格直播BP展示系统" HorizontalAlignment="Center" Margin="0,29,0,0" VerticalAlignment="Top" Width="195"/>
        <Label Content="ASG官网用户名:" HorizontalAlignment="Left" Margin="47,71,0,0" VerticalAlignment="Top" Width="97"/>
        <Label Content="密码：" HorizontalAlignment="Left" Height="25" Margin="105,116,0,0" VerticalAlignment="Top" Width="39"/>
        <TextBox HorizontalAlignment="Left" Margin="150,73,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120" x:Name="AccountBox" Height="21"/>
        <PasswordBox HorizontalAlignment="Left" Margin="150,116,0,0" VerticalAlignment="Top" Width="120" Password="" x:Name="PasswordBox" KeyDown="PasswordBox_KeyDown" Height="23"/>
        <Button Content="取消" HorizontalAlignment="Left" Margin="96,161,0,0" VerticalAlignment="Top" Width="56" Height="25" x:Name="CloseB" Click="CloseB_Click"/>
        <Button Content="登录" HorizontalAlignment="Left" Margin="210,161,0,0" VerticalAlignment="Top" Height="25" Width="55" x:Name="LoginB" Click="LoginB_Click"/>
    </Grid>
</Window>
